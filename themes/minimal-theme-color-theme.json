{
  "$schema": "vscode://schemas/color-theme",
  "name": "Minimal Theme",
  "type": "dark",
  "colors": {
    "editor.background": "#1E1E1E",
    "editor.foreground": "#D4D4D4",
    "editor.selectionBackground": "#264F78",
    "editor.lineHighlightBackground": "#2A2D2E",
    "editorCursor.foreground": "#AEAFAD",
    "editorLineNumber.foreground": "#6A6A6A",
    "activityBar.background": "#333333",
    "activityBar.foreground": "#D4D4D4",
    "activityBar.inactiveForeground": "#858585",
    "activityBarBadge.background": "#007ACC",
    "sideBar.background": "#252526",
    "sideBar.foreground": "#D4D4D4",
    "sideBar.border": "#333333",
    "sideBarTitle.foreground": "#D4D4D4",
    "statusBar.background": "#007ACC",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.debuggingBackground": "#CC6633",
    "titleBar.activeBackground": "#1E1E1E",
    "titleBar.activeForeground": "#D4D4D4",
    "titleBar.inactiveBackground": "#2D2D30",
    "titleBar.inactiveForeground": "#969696",
    "panel.background": "#1E1E1E",
    "panel.foreground": "#D4D4D4",
    "panel.border": "#333333",
    "panelTitle.activeForeground": "#D4D4D4",
    "terminal.background": "#1E1E1E",
    "terminal.foreground": "#D4D4D4",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#CD3131",
    "terminal.ansiGreen": "#0DBC79",
    "terminal.ansiYellow": "#E5E510",
    "terminal.ansiBlue": "#2B90D9",
    "terminal.ansiMagenta": "#BC3FBC",
    "terminal.ansiCyan": "#11A8CD",
    "terminal.ansiWhite": "#E5E5E5"
  },
  "tokenColors": [
    {
      "scope": ["comment", "comment.block"],
      "settings": {
        "foreground": "#6A9955",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "keyword.control"],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "scope": ["variable", "variable.parameter"],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "scope": ["variable.builtin"],
      "settings": {
        "foreground": "#4FC1FF"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "scope": ["string.template"],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "scope": ["constant", "constant.numeric"],
      "settings": {
        "foreground": "#B5CEA8"
      }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "scope": ["entity.name.function"],
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "scope": ["entity.name.class"],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "scope": ["entity.name.type"],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "scope": ["storage.type"],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "scope": ["punctuation.separator"],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    }
  ]
}